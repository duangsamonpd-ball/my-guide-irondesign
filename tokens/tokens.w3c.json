    "75":  { "$value": 0.75, "$type": "number", "$description": "75%" },
    "80":  { "$value": 0.80, "$type": "number", "$description": "80%" },
    "85":  { "$value": 0.85, "$type": "number", "$description": "85%" },
    "90":  { "$value": 0.90, "$type": "number", "$description": "90%" },
    "95":  { "$value": 0.95, "$type": "number", "$description": "95%" },
    "100": { "$value": 1,    "$type": "number", "$description": "Fully opaque" }
  },

  "sizing": {
    "btn-primary-height":   { "$value": 56,   "$type": "dimension", "$description": "Large button" },
    "btn-secondary-height": { "$value": 48,   "$type": "dimension", "$description": "Default button" },
    "btn-small-height":     { "$value": 36,   "$type": "dimension", "$description": "Small button (Figma updated 2026-07-07, was 40)" },
    "input-height":         { "$value": 44,   "$type": "dimension" },
    "nav-height":           { "$value": 40,   "$type": "dimension" },
    "touch-min":            { "$value": 44,   "$type": "dimension" },
    "touch-nav":            { "$value": 48,   "$type": "dimension" },
    "container-max":        { "$value": 1440, "$type": "dimension" }
  },

  "typography": {
    "_source": "Iron Software Typography System — Montserrat (content + UI text)",

    "accent": {
      "$value": "#185FA5",
      "$type": "color",
      "$description": "NuGet blue — overlines and emphasis. Retheme from this one token (--c-accent)."
    },

    "font-family": {
      "body": { "$value": "Montserrat, sans-serif", "$type": "fontFamily", "$description": "All content and UI text. Ships the full 100–900 range, so every weight here is real (no fake-bold)." },
      "mono": { "$value": "Roboto Mono, SF Mono, Cascadia Code, Consolas, monospace", "$type": "fontFamily", "$description": "Inline and block code. Figma specifies Roboto Mono; falls back to the platform system monospace." }
    },

    "font-weight": {
      "regular":   { "$value": 400, "$type": "fontWeight", "$description": "All running text — body, body-large, caption." },
      "medium":    { "$value": 500, "$type": "fontWeight", "$description": "Nav links — wayfinding, lighter than buttons." },
      "semibold":  { "$value": 600, "$type": "fontWeight", "$description": "H4 and all buttons — reads as action, not prose." },
      "bold":      { "$value": 700, "$type": "fontWeight", "$description": "H3, overline, active nav, nav group label." },
      "extrabold": { "$value": 800, "$type": "fontWeight", "$description": "H2 — section headings." },
      "black":     { "$value": 900, "$type": "fontWeight", "$description": "H1 (default and hero) — heaviest level." }
    },

    "size": {
      "xs":   { "$value": "12px", "$type": "dimension" },
      "sm":   { "$value": "14px", "$type": "dimension" },
      "base": { "$value": "16px", "$type": "dimension" },
      "lg":   { "$value": "18px", "$type": "dimension" },
      "xl":   { "$value": "20px", "$type": "dimension" },
      "2xl":  { "$value": "24px", "$type": "dimension" },
      "3xl":  { "$value": "30px", "$type": "dimension" },
      "4xl":  { "$value": "36px", "$type": "dimension" },
      "5xl":  { "$value": "40px", "$type": "dimension" },
      "6xl":  { "$value": "48px", "$type": "dimension" },
      "7xl":  { "$value": "60px", "$type": "dimension" },
      "8xl":  { "$value": "72px", "$type": "dimension" },
      "9xl":  { "$value": "96px", "$type": "dimension" }
    },

    "leading": {
      "3":  { "$value": "12px",  "$type": "dimension" },
      "4":  { "$value": "16px",  "$type": "dimension" },
      "5":  { "$value": "20px",  "$type": "dimension" },
      "6":  { "$value": "24px",  "$type": "dimension" },
      "7":  { "$value": "28px",  "$type": "dimension" },
      "8":  { "$value": "32px",  "$type": "dimension" },
      "9":  { "$value": "36px",  "$type": "dimension" },
      "10": { "$value": "40px",  "$type": "dimension" },
      "12": { "$value": "48px",  "$type": "dimension" },
      "15": { "$value": "60px",  "$type": "dimension" },
      "18": { "$value": "72px",  "$type": "dimension" },
      "24": { "$value": "96px",  "$type": "dimension" },
      "32": { "$value": "128px", "$type": "dimension" }
    },

    "scale": {
      "h1-hero": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "48px", "fontWeight": 900, "lineHeight": "48px", "letterSpacing": "-0.8px" },
        "$description": "Hero variant of H1 — still a real <h1>. A size modifier (h1.hero) used once on the homepage hero for maximum impact. No separate non-semantic Display level."
      },
      "h1": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "40px", "fontWeight": 900, "lineHeight": "48px", "letterSpacing": "-0.8px" },
        "$description": "The page's main title — exactly one per page. Largest level; carries SEO/screen-reader meaning. Inner pages use this; homepage adds the hero modifier."
      },
      "h2": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "30px", "fontWeight": 800, "lineHeight": "36px", "letterSpacing": "-0.4px" },
        "$description": "Major section headings within a page. Used every time a new top-level content block begins. Often paired with an Overline above."
      },
      "h3": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "24px", "fontWeight": 700, "lineHeight": "32px", "letterSpacing": "-0.4px" },
        "$description": "Sub-headings within a section, or card / feature titles. The most frequently used heading because of the many feature cards."
      },
      "h4": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "20px", "fontWeight": 800, "lineHeight": "28px", "letterSpacing": "-0.4px" },
        "$description": "Card titles and sub-sub-headings inside multi-level cards. Equals Body large (20px) — separated by weight (800 vs 400) and tight tracking."
      },
      "title-large": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "18px", "fontWeight": 700, "lineHeight": "28px" },
        "$description": "A titled heading at body-large size — heavier than Body large, lighter than H4. Section intro labels or named headings inside running content."
      },
      "body-large": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "18px", "fontWeight": 500, "lineHeight": "28px" },
        "$description": "Lead / intro paragraphs sitting under a major heading. Medium 500 (Figma) gives the lead sentence more presence than body without being a heading."
      },
      "quote": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "18px", "fontWeight": 500, "lineHeight": "28px", "fontStyle": "italic" },
        "$description": "Pull quotes, testimonials, blockquotes. Same size/weight as Body large but italic — visually distinct without a separate size."
      },
      "body": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "16px", "fontWeight": 400, "lineHeight": "28px" },
        "$description": "The default for all running text. Line-height 28px (token 7) for comfortable reading. Baseline for anything that isn't a heading."
      },
      "caption": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "14px", "fontWeight": 400, "lineHeight": "20px" },
        "$description": "Supporting text, one step smaller — captions, meta, footnotes, trust badges. Uses the secondary colour so it recedes."
      },
      "caption-sm": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "12px", "fontWeight": 500, "lineHeight": "16px", "letterSpacing": "0.4px" },
        "$description": "Smallest text — tooltips and footer fine print. 12px / 500 / line-height 16px (token 4) / tracking 0.4px keeps it legible. Use sparingly and only in a secondary colour."
      },
      "label": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "14px", "fontWeight": 500, "lineHeight": "20px", "letterSpacing": "0px" },
        "$description": "Form and UI labels. 14px / 500 (medium) / line-height 20px (token 5). Medium weight separates a label from the value or body text beside it."
      },
      "overline": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "14px", "fontWeight": 700, "lineHeight": "16px", "letterSpacing": "0.8px", "textTransform": "uppercase" },
        "$description": "Uppercase category label above a major heading. Accent colour with wider tracking so all-caps stays readable. Almost always paired with H2/H3."
      },
      "code": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.mono}", "fontSize": "14px", "fontWeight": 400, "lineHeight": "24px" },
        "$description": "C# code, inline and block. Always monospace, light background, thin border to separate from prose."
      }
    },

    "ui": {
      "button-large": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "16px", "fontWeight": 700, "lineHeight": 1, "letterSpacing": "0px" },
        "$description": "Hero and primary page CTAs. Weight 700 (bold) reads as a strong action. Line-height 1 — vertical centring via padding (~14×26px). Matches Body size but heavier/tighter."
      },
      "button-default": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "14px", "fontWeight": 600, "lineHeight": "16px", "letterSpacing": "0px" },
        "$description": "Standard buttons in cards and sections. Everyday button size, padding ~10×18px. Line-height 16px (token 4 / leading-4). Matches Caption size but heavier."
      },
      "button-small": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "12px", "fontWeight": 600, "lineHeight": 1, "letterSpacing": "0.4px" },
        "$description": "Compact, inline, and table actions. Wider tracking keeps bold legible. On mobile keep tappable area ≥40px tall via padding."
      },
      "nav-primary": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "16px", "fontWeight": 500, "lineHeight": 1 },
        "$description": "Main navigation links in the top bar. Lighter (500) — wayfinding not action. Active item uses weight 700 + accent colour."
      },
      "nav-dropdown": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "14px", "fontWeight": 500, "lineHeight": "20px" },
        "$description": "Dropdown items, footer links, sidebar entries. Line-height 20px (not 1) because these can wrap to two lines."
      },
      "nav-group-label": {
        "$type": "typography",
        "$value": { "fontFamily": "{typography.font-family.body}", "fontSize": "12px", "fontWeight": 700, "lineHeight": "16px", "letterSpacing": "0.4px", "textTransform": "uppercase" },
        "$description": "Category headers inside menus and footer columns. Like Overline but tighter tracking and a neutral colour — organises rather than draws attention."
      }
    }
  }
}
