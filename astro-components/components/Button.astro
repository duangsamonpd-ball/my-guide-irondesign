---
interface Props {
  variant?: 'primary' | 'secondary' | 'tertiary' | 'outline' | 'ondark' | 'ghost';
  size?: 'lg' | 'md' | 'sm';
  disabled?: boolean;
  type?: 'button' | 'submit' | 'reset';
  href?: string;
  class?: string;
}

const {
  variant = 'primary',
  size = 'md',
  disabled = false,
  type = 'button',
  href,
  class: className,
} = Astro.props;

const Tag = href ? 'a' : 'button';
---

<Tag
  class:list={['btn', `btn--${size}`, `btn--${variant}`, className]}
  href={href}
  type={href ? undefined : type}
  disabled={href ? undefined : disabled}
  aria-disabled={href && disabled ? 'true' : undefined}
>
  <slot />
</Tag>

<style>
  .btn {
    cursor: pointer; display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    font-family: 'Montserrat', sans-serif; border: 2px solid transparent; outline: none;
    border-radius: var(--rounded-cta); white-space: nowrap; text-decoration: none;
    transition: background .15s, color .15s, border-color .15s, box-shadow .15s;
  }
  /* sizes */
  .btn--lg { height: var(--size-btn-lg); padding: 0 26px; font-size: var(--font-size-btn-lg); font-weight: var(--fw-btn-lg); letter-spacing: 0; }
  .btn--md { height: var(--size-btn-md); padding: 0 20px; font-size: var(--font-size-btn); font-weight: var(--fw-btn); letter-spacing: 0; }
  .btn--sm { height: var(--size-btn-sm); padding: 0 16px; font-size: var(--font-size-btn-sm); font-weight: var(--fw-btn); letter-spacing: 0.4px; }
  /* variants — solid */
  .btn--primary   { background: var(--color-primary); color: var(--color-primary-on); }
  .btn--primary:hover   { background: var(--color-primary-hover); }
  .btn--secondary { background: var(--color-secondary); color: var(--color-primary-on); }
  .btn--secondary:hover { background: var(--color-secondary-hover); }
  .btn--tertiary  { background: var(--color-button-tertiary); color: var(--color-primary-on); }
  .btn--tertiary:hover  { background: var(--color-primary); }   /* black → pink */
  /* variants — outline / ghost (blue text → pink on hover) */
  .btn--outline   { background: #fff; color: var(--color-on-tertiary); border-color: var(--color-border); }
  .btn--outline:hover   { border-color: var(--color-border-strong); color: var(--color-on-tertiary-hover); }
  .btn--ondark    { background: var(--ondark-tint); color: var(--color-on-tertiary); border-color: var(--color-border); backdrop-filter: blur(4px); }
  .btn--ondark:hover    { color: var(--color-on-tertiary-hover); }
  .btn--ghost     { background: transparent; color: var(--color-on-tertiary); }
  .btn--ghost:hover     { background: var(--ghost-hover); color: var(--color-on-tertiary-hover); }
  /* focus rings */
  .btn--primary:focus-visible   { box-shadow: var(--shadow-focus-magenta); }
  .btn--secondary:focus-visible { box-shadow: var(--focus-ring-blue); }
  .btn--tertiary:focus-visible  { box-shadow: var(--focus-ring-white); }
  .btn--outline:focus-visible   { box-shadow: var(--focus-ring-blue); }
  .btn--ondark:focus-visible    { box-shadow: var(--focus-ring-blue); border-color: rgba(255,255,255,0.3); }
  .btn--ghost:focus-visible     { border-color: var(--color-border-focused); }
  .btn[disabled], .btn[aria-disabled="true"] { opacity: .5; cursor: not-allowed; pointer-events: none; }
</style>
