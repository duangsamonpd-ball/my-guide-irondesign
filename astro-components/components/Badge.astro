---
interface Props {
  intent?: 'success' | 'warning' | 'danger' | 'info' | 'important' | 'neutral';
  solid?: boolean;
  small?: boolean;
  pill?: boolean;
  dot?: boolean;
  dark?: boolean;
  class?: string;
}

const {
  intent = 'neutral',
  solid = false,
  small = false,
  pill = false,
  dot = false,
  dark = false,
  class: className,
} = Astro.props;
---

<span class:list={['badge', `badge--${intent}`, { solid, sm: small, pill, dark }, className]}>
  {dot && <span class="bdot"></span>}
  <slot />
</span>

<style>
  /*
    Subtle fill = --color-{intent}-subtle (iron-*-100), text = --color-{intent}-strong
    (iron-*-700) — verified against Figma node 776-899 ("Badge"), which uses exactly
    these pairs. All six intents consume the semantic subtle/strong tokens (added from
    the Figma color_ui export); no primitive is referenced directly in light mode.
    Dark variant mirrors the pattern with the *-900 (fill) / *-300 (text) pair for
    contrast on dark backgrounds — Figma has no dark-mode Badge spec, so this follows
    the existing dark-tint convention (see --color-bg-dark-card / --color-text-dark-support).
    Default shape is --rounded-sm (Figma node 776-899 uses this on every badge, not a
    pill) — the old default was --rounded-full; `pill` now opts back into that shape.
  */
  .badge {
    display: inline-flex; align-items: center; gap: var(--spacing-micro);
    font-family: 'Montserrat', sans-serif; font-size: var(--font-size-xs); font-weight: 700;
    line-height: 1; padding: 5px 10px; border-radius: var(--rounded-sm); white-space: nowrap; letter-spacing: 0.01em;
  }
  .badge .bdot { width: 6px; height: 6px; border-radius: var(--rounded-full); background: currentColor; }

  .badge--success   { background: var(--color-success-subtle); color: var(--color-success-strong); }
  .badge--warning   { background: var(--color-warning-subtle); color: var(--color-warning-strong); }
  .badge--danger    { background: var(--color-danger-subtle);  color: var(--color-danger-strong); }
  .badge--info      { background: var(--color-info-subtle);    color: var(--color-info-strong); }
  .badge--important { background: var(--color-important-subtle); color: var(--color-important-strong); }
  .badge--neutral   { background: var(--color-neutral-subtle);   color: var(--color-neutral-strong); }

  .badge.dark.badge--success   { background: var(--iron-green-900);  color: var(--iron-green-300); }
  .badge.dark.badge--warning   { background: var(--iron-orange-900); color: var(--iron-orange-300); }
  .badge.dark.badge--danger    { background: var(--iron-red-900);    color: var(--iron-red-300); }
  .badge.dark.badge--info      { background: var(--iron-blue-900);   color: var(--iron-blue-300); }
  .badge.dark.badge--important { background: var(--iron-purple-900); color: var(--iron-purple-300); }
  .badge.dark.badge--neutral   { background: var(--slate-800);       color: var(--slate-300); }

  .badge.solid { color: var(--color-primary-on); }
  .badge.solid.badge--success   { background: var(--color-success); }
  .badge.solid.badge--warning   { background: var(--color-warning); }
  .badge.solid.badge--danger    { background: var(--color-danger); }
  .badge.solid.badge--info      { background: var(--color-secondary); }
  .badge.solid.badge--important { background: var(--color-important); }
  .badge.solid.badge--neutral   { background: var(--color-neutral); }

  .badge.sm { font-size: 11px; padding: 3px 8px; }
  .badge.pill { border-radius: var(--rounded-full); }
</style>
