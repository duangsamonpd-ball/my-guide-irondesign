---
interface Props {
  icon: 'quote' | 'key' | 'check';
  title: string;
  subtitle?: string;
  submitLabel: string;
  noteLeft?: string;
  noteRight?: string;
  class?: string;
}

const { icon, title, subtitle, submitLabel, noteLeft, noteRight, class: className } = Astro.props;

// Font Awesome Free Solid path data — file-invoice, key, check
const icons = {
  quote: { viewBox: '0 0 384 512', path: 'M64 0C28.7 0 0 28.7 0 64L0 448c0 35.3 28.7 64 64 64l256 0c35.3 0 64-28.7 64-64l0-277.5c0-17-6.7-33.3-18.7-45.3L258.7 18.7C246.7 6.7 230.5 0 213.5 0L64 0zM325.5 176L232 176c-13.3 0-24-10.7-24-24L208 58.5 325.5 176zM64 384l0-64c0-17.7 14.3-32 32-32l192 0c17.7 0 32 14.3 32 32l0 64c0 17.7-14.3 32-32 32L96 416c-17.7 0-32-14.3-32-32zM88 64l48 0c13.3 0 24 10.7 24 24s-10.7 24-24 24l-48 0c-13.3 0-24-10.7-24-24S74.7 64 88 64zm0 96l48 0c13.3 0 24 10.7 24 24s-10.7 24-24 24l-48 0c-13.3 0-24-10.7-24-24s10.7-24 24-24z' },
  key: { viewBox: '0 0 512 512', path: 'M336 352c97.2 0 176-78.8 176-176S433.2 0 336 0 160 78.8 160 176c0 18.7 2.9 36.8 8.3 53.7L7 391c-4.5 4.5-7 10.6-7 17l0 80c0 13.3 10.7 24 24 24l80 0c13.3 0 24-10.7 24-24l0-40 40 0c13.3 0 24-10.7 24-24l0-40 40 0c6.4 0 12.5-2.5 17-7l33.3-33.3c16.9 5.4 35 8.3 53.7 8.3zM376 96a40 40 0 1 1 0 80 40 40 0 1 1 0-80z' },
  check: { viewBox: '0 0 448 512', path: 'M434.8 70.1c14.3 10.4 17.5 30.4 7.1 44.7l-256 352c-5.5 7.6-14 12.3-23.4 13.1s-18.5-2.7-25.1-9.3l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l101.5 101.5 234-321.7c10.4-14.3 30.4-17.5 44.7-7.1z' },
} as const;
---

<div class:list={['form-card', className]}>
  <div class="fc-title">
    <span class="fc-icon"><svg viewBox={icons[icon].viewBox} fill="currentColor"><path d={icons[icon].path} /></svg></span>
    <div class="fc-heading">
      <h3>{title}</h3>
      {subtitle && <p>{subtitle}</p>}
    </div>
  </div>
  <div class="fc-fields">
    <slot />
  </div>
  <div class="fc-last">
    <button type="submit" class="fc-submit">{submitLabel} <span class="arr">→</span></button>
    {(noteLeft || noteRight) && (
      <div class="fc-notes">
        {noteLeft && <span>{noteLeft}</span>}
        {noteLeft && noteRight && <span class="fc-sep"></span>}
        {noteRight && <span>{noteRight}</span>}
      </div>
    )}
  </div>
</div>

<style>
  .form-card {
    background: var(--color-bg-base); border: 1px solid var(--color-border); border-radius: var(--rounded-2xl);
    padding: 32px; display: flex; flex-direction: column; gap: 24px; max-width: 540px;
  }
  .fc-title { display: flex; align-items: center; gap: 16px; }
  .fc-icon {
    width: 64px; height: 64px; flex-shrink: 0; border-radius: var(--rounded-lg);
    background: rgba(38,147,236,0.06); border: 1px solid rgba(38,147,236,0.10);
    display: flex; align-items: center; justify-content: center; color: var(--color-secondary);
  }
  .fc-icon svg { width: 26px; height: 26px; }
  .fc-heading h3 { font-family: 'Montserrat', sans-serif; font-size: 1.25rem; font-weight: 700; color: var(--color-text-heading); }
  .fc-heading p { font-family: 'Montserrat', sans-serif; font-size: 0.9rem; color: var(--color-text-support); margin-top: 4px; }
  .fc-fields { display: flex; flex-direction: column; gap: 20px; }
  .fc-fields :global(.field) { max-width: none; }
  .fc-last { display: flex; flex-direction: column; gap: 12px; }
  .fc-submit {
    width: 100%; height: var(--size-btn-lg); border: none; border-radius: var(--rounded-cta);
    background: var(--color-primary); color: var(--color-primary-on); font-family: 'Montserrat', sans-serif;
    font-size: var(--font-size-btn-lg); font-weight: var(--fw-btn-lg); cursor: pointer;
    display: inline-flex; align-items: center; justify-content: center; gap: 8px;
    transition: background .15s;
  }
  .fc-submit:hover { background: var(--color-primary-hover); }
  .fc-submit .arr { transition: transform .16s; }
  .fc-submit:hover .arr { transform: translateX(3px); }
  .fc-notes { display: flex; align-items: center; justify-content: center; gap: 12px; font-size: 0.78rem; color: var(--color-text-support); }
  .fc-sep { width: 3px; height: 3px; border-radius: 50%; background: var(--color-border-strong); }
</style>
