---
interface Props {
  variant?: 'filled' | 'bordered';
  intent?: 'info' | 'success' | 'important' | 'warning' | 'danger';
  title: string;
  text: string;
  class?: string;
}

const { variant = 'filled', intent = 'info', title, text, class: className } = Astro.props;

// Font Awesome Free Solid path data (circle-info, circle-check, circle-exclamation,
// triangle-exclamation, circle-xmark) — all share a 0 0 512 512 viewBox.
const iconPathFor = {
  info: 'M256 512a256 256 0 1 0 0-512 256 256 0 1 0 0 512zM224 160a32 32 0 1 1 64 0 32 32 0 1 1 -64 0zm-8 64l48 0c13.3 0 24 10.7 24 24l0 88 8 0c13.3 0 24 10.7 24 24s-10.7 24-24 24l-80 0c-13.3 0-24-10.7-24-24s10.7-24 24-24l24 0 0-64-24 0c-13.3 0-24-10.7-24-24s10.7-24 24-24z',
  success: 'M256 512a256 256 0 1 1 0-512 256 256 0 1 1 0 512zM374 145.7c-10.7-7.8-25.7-5.4-33.5 5.3L221.1 315.2 169 263.1c-9.4-9.4-24.6-9.4-33.9 0s-9.4 24.6 0 33.9l72 72c5 5 11.8 7.5 18.8 7s13.4-4.1 17.5-9.8L379.3 179.2c7.8-10.7 5.4-25.7-5.3-33.5z',
  important: 'M256 512a256 256 0 1 1 0-512 256 256 0 1 1 0 512zm0-192a32 32 0 1 0 0 64 32 32 0 1 0 0-64zm0-192c-18.2 0-32.7 15.5-31.4 33.7l7.4 104c.9 12.6 11.4 22.3 23.9 22.3 12.6 0 23-9.7 23.9-22.3l7.4-104c1.3-18.2-13.1-33.7-31.4-33.7z',
  warning: 'M256 0c14.7 0 28.2 8.1 35.2 21l216 400c6.7 12.4 6.4 27.4-.8 39.5S486.1 480 472 480L40 480c-14.1 0-27.2-7.4-34.4-19.5s-7.5-27.1-.8-39.5l216-400c7-12.9 20.5-21 35.2-21zm0 352a32 32 0 1 0 0 64 32 32 0 1 0 0-64zm0-192c-18.2 0-32.7 15.5-31.4 33.7l7.4 104c.9 12.5 11.4 22.3 23.9 22.3 12.6 0 23-9.7 23.9-22.3l7.4-104c1.3-18.2-13.1-33.7-31.4-33.7z',
  danger: 'M256 512a256 256 0 1 0 0-512 256 256 0 1 0 0 512zM167 167c9.4-9.4 24.6-9.4 33.9 0l55 55 55-55c9.4-9.4 24.6-9.4 33.9 0s9.4 24.6 0 33.9l-55 55 55 55c9.4 9.4 9.4 24.6 0 33.9s-24.6 9.4-33.9 0l-55-55-55 55c-9.4 9.4-24.6 9.4-33.9 0s-9.4-24.6 0-33.9l55-55-55-55c-9.4-9.4-9.4-24.6 0-33.9z',
} as const;
---

<div class:list={['notice', `notice--${variant}`, `notice--${intent}`, className]}>
  {variant === 'filled' ? (
    <>
      <div class="notice-header">
        <svg class="notice-icon" viewBox="0 0 512 512" fill="currentColor"><path d={iconPathFor[intent]} /></svg>
        <span class="notice-title">{title}</span>
      </div>
      <p class="notice-text">{text}</p>
    </>
  ) : (
    <p class="notice-text"><svg class="notice-icon" viewBox="0 0 512 512" fill="currentColor"><path d={iconPathFor[intent]} /></svg> <b>{title}:</b> {text}</p>
  )}
</div>

<style>
  .notice { display: flex; flex-direction: column; gap: 8px; padding: 24px; max-width: 560px; }
  .notice-icon { width: 1rem; height: 1rem; flex-shrink: 0; vertical-align: -0.1em; }
  .notice-header { display: flex; align-items: center; gap: 8px; }
  .notice-title { font-family: 'Montserrat', sans-serif; font-size: 1.05rem; font-weight: 700; color: var(--color-text-heading); }
  .notice-text { font-family: 'Montserrat', sans-serif; font-size: 0.95rem; line-height: 1.6; }
  .notice-text b { font-weight: 700; }

  /* filled — tinted rounded card, only the icon carries the intent colour */
  .notice--filled { border-radius: var(--rounded-lg); }
  .notice--filled .notice-text { color: var(--color-text-heading); }

  /* bordered — no fill, a coloured left bar; icon carries the intent colour, text stays neutral */
  .notice--bordered { border-left: 3px solid; padding: 0 0 0 20px; }
  .notice--bordered .notice-text { color: var(--color-text-body); }

  .notice--info.notice--filled { background: var(--color-bg-card-alt); }
  .notice--info .notice-icon { color: var(--color-info); }
  .notice--info.notice--bordered { border-left-color: var(--color-info); }

  .notice--success.notice--filled { background: var(--iron-green-50); }
  .notice--success .notice-icon { color: var(--color-success); }
  .notice--success.notice--bordered { border-left-color: var(--color-success); }

  .notice--important.notice--filled { background: var(--iron-purple-50); }
  .notice--important .notice-icon { color: var(--iron-purple-500); }
  .notice--important.notice--bordered { border-left-color: var(--iron-purple-500); }

  .notice--warning.notice--filled { background: var(--iron-orange-50); }
  .notice--warning .notice-icon { color: var(--color-warning); }
  .notice--warning.notice--bordered { border-left-color: var(--color-warning); }

  .notice--danger.notice--filled { background: var(--iron-red-50); }
  .notice--danger .notice-icon { color: var(--color-danger); }
  .notice--danger.notice--bordered { border-left-color: var(--color-danger); }
</style>
