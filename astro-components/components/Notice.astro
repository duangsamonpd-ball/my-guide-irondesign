---
interface Props {
  intent?: 'info' | 'success' | 'warning' | 'danger';
  title?: string;
  leadIn?: string;
  text: string;
  class?: string;
}

const iconFor = { info: '✓', success: '✓', warning: '!', danger: '✕' } as const;

const { intent = 'info', title, leadIn, text, class: className } = Astro.props;

const isMinimal = !title && !leadIn;
---

<div class:list={['notice', `notice--${intent}`, className]}>
  <span class="notice-icon">{iconFor[intent]}</span>
  <div class="notice-content">
    {title && <div class="notice-title">{title}</div>}
    {isMinimal ? (
      <span class="notice-label">{text}</span>
    ) : (
      <p class="notice-text">{leadIn && <b>{leadIn}: </b>}{text}</p>
    )}
  </div>
</div>

<style>
  .notice { display: flex; align-items: flex-start; gap: 12px; padding: 24px; border-radius: var(--rounded-lg); max-width: 520px; }
  .notice-icon { flex-shrink: 0; width: 24px; height: 24px; display: flex; align-items: center; justify-content: center; font-size: 1.2rem; line-height: 1; margin-top: 2px; }
  .notice-content { display: flex; flex-direction: column; gap: 8px; }
  .notice-title { font-family: 'Montserrat', sans-serif; font-size: 1.125rem; font-weight: 700; color: var(--color-text-heading); }
  .notice-text { font-family: 'Montserrat', sans-serif; font-size: 1rem; color: var(--color-text-heading); line-height: 1.6; }
  .notice-text b { font-weight: 700; }
  .notice-label { font-family: 'Montserrat', sans-serif; font-size: 1.125rem; font-weight: 700; }

  .notice--info { background: var(--color-bg-card-alt); }
  .notice--info .notice-icon, .notice--info .notice-label { color: var(--color-secondary); }

  .notice--success { background: var(--iron-green-50); }
  .notice--success .notice-icon { color: var(--color-success-hover); }
  .notice--success .notice-label { color: var(--color-success); }

  .notice--warning { background: var(--iron-orange-50); }
  .notice--warning .notice-icon { color: var(--color-warning-hover); }
  .notice--warning .notice-label { color: var(--color-warning); }

  .notice--danger { background: var(--iron-red-50); }
  .notice--danger .notice-icon { color: var(--color-danger-hover); }
  .notice--danger .notice-label { color: var(--color-danger); }
</style>
