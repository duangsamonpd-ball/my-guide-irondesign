---
interface Props {
  href: string;
  dark?: boolean;
  external?: boolean;
  class?: string;
}

const { href, dark = false, external = false, class: className } = Astro.props;

const externalProps = external ? { target: '_blank', rel: 'noopener' } : {};
---

<a href={href} class:list={['tlink', { dark }, className]} {...externalProps}>
  <slot />
  {external && <span class="ext-icon">↗</span>}
</a>

<style>
  /* Neutral-coloured text with a separate underline — only the underline's
     opacity changes on hover (50% → 100%), the text colour never does. */
  .tlink {
    color: var(--color-text-heading); font-weight: 600;
    text-decoration: underline; text-decoration-color: color-mix(in srgb, var(--color-border-selected) 50%, transparent);
    text-decoration-thickness: 1px; text-underline-offset: 3px;
    transition: text-decoration-color .15s;
  }
  .tlink:hover { text-decoration-color: var(--color-border-selected); }
  .tlink:focus-visible { outline: 2px solid var(--color-border-selected); outline-offset: 3px; border-radius: 2px; }
  .tlink.dark { color: var(--color-text-dark-heading); text-decoration-color: color-mix(in srgb, var(--color-border-dark-alt) 50%, transparent); }
  .tlink.dark:hover { text-decoration-color: var(--color-border-dark-alt); }
  .tlink.dark:focus-visible { outline-color: var(--color-border-dark-alt); }
  .tlink .ext-icon { font-size: 0.7em; margin-left: 3px; }
</style>
