---
interface Props {
  href: string;
  dark?: boolean;
  external?: boolean;
  class?: string;
}

const { href, dark = false, external = false, class: className } = Astro.props;

const externalProps = external ? { target: '_blank', rel: 'noopener' } : {};
---

<a href={href} class:list={['tlink', { dark }, className]} {...externalProps}>
  <slot />
  {external && <span class="ext-icon">↗</span>}
</a>

<style>
  .tlink {
    color: var(--color-text-link); text-decoration: underline; text-underline-offset: 3px;
    font-weight: 600; transition: color .15s;
  }
  .tlink:hover { color: var(--color-text-link-hover); }
  .tlink:focus-visible { outline: 2px solid var(--color-text-link); outline-offset: 3px; border-radius: 2px; }
  .tlink.dark { color: var(--color-text-dark-link); }
  .tlink.dark:hover { color: var(--color-text-dark-link-hover); }
  .tlink.dark:focus-visible { outline-color: var(--color-text-dark-link); }
  .tlink .ext-icon { font-size: 0.7em; margin-left: 3px; }
</style>
