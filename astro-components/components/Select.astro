---
interface Option {
  value: string;
  label: string;
}

interface Props {
  label?: string;
  options: Option[];
  value?: string;
  placeholder?: string;
  name?: string;
  error?: boolean;
  errorMessage?: string;
  hint?: string;
  disabled?: boolean;
  class?: string;
}

const {
  label,
  options,
  value,
  placeholder = 'Select…',
  name,
  error = false,
  errorMessage,
  hint,
  disabled = false,
  class: className,
} = Astro.props;

const selected = options.find((o) => o.value === value);
---

<div class:list={['sel', className, { error, disabled }]}>
  {label && <label class="sel-label">{label}</label>}
  <button type="button" class:list={['sel-trigger', { 'is-placeholder': !selected }]} disabled={disabled}>
    <span class="sel-value">{selected ? selected.label : placeholder}</span>
    <span class="chev">▾</span>
  </button>
  <div class="sel-menu">
    {options.map((opt) => (
      <div class:list={['sel-opt', { selected: opt.value === value }]} data-value={opt.value}>
        {opt.label} <span class="ck"><svg viewBox="0 0 448 512" fill="currentColor"><path d="M434.8 70.1c14.3 10.4 17.5 30.4 7.1 44.7l-256 352c-5.5 7.6-14 12.3-23.4 13.1s-18.5-2.7-25.1-9.3l-128-128c-12.5-12.5-12.5-32.8 0-45.3s32.8-12.5 45.3 0l101.5 101.5 234-321.7c10.4-14.3 30.4-17.5 44.7-7.1z"/></svg></span>
      </div>
    ))}
  </div>
  <!-- native select carries the real form value; visually hidden, drives progressive enhancement -->
  <select name={name} class="sel-native-fallback" disabled={disabled} required>
    <option value="" disabled selected={!value}>{placeholder}</option>
    {options.map((opt) => <option value={opt.value} selected={opt.value === value}>{opt.label}</option>)}
  </select>
  {error && errorMessage ? (
    <span class="sel-err">{errorMessage}</span>
  ) : hint ? (
    <span class="sel-hint">{hint}</span>
  ) : null}
</div>

<style>
  .sel { position: relative; width: 100%; max-width: 280px; }
  .sel-label { display: block; font-size: var(--font-size-label); font-weight: var(--fw-label); color: var(--color-text-heading); margin-bottom: 6px; }
  .sel-trigger {
    width: 100%; height: var(--size-input);
    border: 1.5px solid var(--color-border); border-radius: var(--rounded-md);
    background: var(--color-bg-base); padding: 0 14px;
    display: flex; align-items: center; justify-content: space-between; gap: 10px;
    font-family: 'Montserrat', sans-serif; font-size: var(--font-size-body); color: var(--color-text-body);
    cursor: pointer; outline: none; transition: border-color .15s, box-shadow .15s;
  }
  .sel-trigger:hover { border-color: var(--color-border-strong); }
  .sel-trigger.is-placeholder { color: var(--color-text-muted); }
  .sel-trigger .chev { color: var(--color-text-support); transition: transform .18s; font-size: 0.8rem; }
  .sel.open .sel-trigger { border-color: var(--color-secondary); box-shadow: var(--shadow-focus-blue); }
  .sel.open .sel-trigger .chev { transform: rotate(180deg); }
  .sel.error .sel-trigger { border-color: var(--color-danger); }
  .sel.disabled .sel-trigger { background: var(--color-bg-shade); color: var(--color-text-muted); cursor: not-allowed; }
  .sel-menu {
    position: absolute; top: calc(100% + 6px); left: 0; right: 0;
    background: #fff; border: 1px solid var(--color-border); border-radius: var(--rounded-lg);
    box-shadow: var(--shadow-float); padding: 6px; z-index: 5; display: none;
  }
  .sel.open .sel-menu { display: block; }
  .sel-opt {
    display: flex; align-items: center; justify-content: space-between; gap: 8px;
    padding: 9px 12px; border-radius: var(--rounded-md);
    font-size: var(--font-size-body); color: var(--color-text-body); cursor: pointer;
  }
  .sel-opt:hover { background: var(--color-bg-shade); }
  .sel-opt.selected { background: var(--color-bg-card-alt); color: var(--color-secondary); font-weight: 600; }
  .sel-opt .ck { color: var(--color-secondary); opacity: 0; display: inline-flex; }
  .sel-opt .ck svg { width: 0.8rem; height: 0.8rem; }
  .sel-opt.selected .ck { opacity: 1; }
  .sel-hint { display: block; font-size: var(--font-size-caption); color: var(--color-text-support); margin-top: 6px; }
  .sel-err  { display: block; font-size: var(--font-size-caption); color: var(--color-danger); font-weight: 500; margin-top: 6px; }
  .sel-native-fallback { position: absolute; inset: 0; opacity: 0; pointer-events: none; }
</style>

<script>
  function initSelects(root: ParentNode = document) {
    root.querySelectorAll<HTMLElement>('.sel:not([data-sel-init])').forEach((sel) => {
      sel.dataset.selInit = '1';
      const trigger = sel.querySelector<HTMLButtonElement>('.sel-trigger');
      const menu = sel.querySelector<HTMLElement>('.sel-menu');
      const valueEl = sel.querySelector<HTMLElement>('.sel-value');
      const nativeSelect = sel.querySelector<HTMLSelectElement>('select');

      trigger?.addEventListener('click', () => {
        if (sel.classList.contains('disabled')) return;
        sel.classList.toggle('open');
      });

      menu?.querySelectorAll<HTMLElement>('.sel-opt').forEach((opt) => {
        opt.addEventListener('click', () => {
          menu.querySelectorAll('.sel-opt').forEach((o) => o.classList.remove('selected'));
          opt.classList.add('selected');
          if (valueEl) valueEl.textContent = opt.childNodes[0]?.textContent?.trim() ?? '';
          trigger?.classList.remove('is-placeholder');
          if (nativeSelect) nativeSelect.value = opt.dataset.value ?? '';
          sel.classList.remove('open');
          sel.dispatchEvent(new CustomEvent('select-change', { detail: opt.dataset.value, bubbles: true }));
        });
      });
    });
  }

  document.addEventListener('click', (e) => {
    if (!(e.target as HTMLElement).closest('.sel')) {
      document.querySelectorAll('.sel.open').forEach((s) => s.classList.remove('open'));
    }
  });

  document.addEventListener('DOMContentLoaded', () => initSelects());
  document.addEventListener('astro:page-load', () => initSelects());
</script>
