---
import { randomUUID } from 'node:crypto';

interface Props {
  title?: string;
  body: string;
  linkHref?: string;
  linkText?: string;
  placement?: 'above' | 'below' | 'left' | 'right';
  maxWidth?: boolean;
  class?: string;
}

const {
  title,
  body,
  linkHref,
  linkText,
  placement = 'above',
  maxWidth = false,
  class: className,
} = Astro.props;

const arrowFor = { above: 'arrow-bottom', below: 'arrow-top', left: 'arrow-right', right: 'arrow-left' } as const;

// Unique per instance so aria-describedby ties the trigger to this bubble even
// when several tooltips render on the same page.
const ttId = `tt-${randomUUID().slice(0, 8)}`;
---

<span class:list={['tt', 'show-on-hover', className]} tabindex="0" aria-describedby={ttId}>
  <slot />
  <span id={ttId} role="tooltip" class:list={['tt-bubble', placement, { max: maxWidth }]}>
    <span class:list={['tt-arrow', arrowFor[placement]]}></span>
    <!-- .tt-content holds the rounded, filled box; keeps the arrow un-clipped -->
    <span class="tt-content">
      {title && <span class="tt-title">{title}</span>}
      <span class="tt-body">{body}</span>
      {linkHref && linkText && (
        <a class="tt-link" href={linkHref}>{linkText} →</a>
      )}
    </span>
  </span>
</span>

<style>
  .tt { position: relative; display: inline-block; }
  .tt-bubble { position: absolute; width: 200px; display: none; flex-direction: column; z-index: 20; text-align: left; }
  .tt-bubble.js-open { display: flex; }
  .tt-bubble.max { width: 350px; }
  .tt-bubble.above { bottom: calc(100% + 10px); left: 50%; transform: translateX(-50%); }
  .tt-bubble.below { top: calc(100% + 10px); left: 50%; transform: translateX(-50%); }
  .tt-bubble.right { left: calc(100% + 10px); top: 50%; transform: translateY(-50%); }
  .tt-bubble.left  { right: calc(100% + 10px); top: 50%; transform: translateY(-50%); }
  /* .tt-content is separate from .tt-bubble so overflow:hidden (needed to clip the
     title bar's square corners) doesn't also clip the arrow poking out of .tt-bubble */
  .tt-content { background: var(--neutral-800); border-radius: var(--rounded-sm); box-shadow: var(--shadow-tooltip); overflow: hidden; display: flex; flex-direction: column; }
  .tt-title { padding: 8px 16px; font-size: 14px; font-weight: 700; color: var(--color-text-on-color-heading); background: var(--neutral-950); line-height: 1.3; }
  .tt-body { padding: 12px 16px 16px; font-size: 12px; font-weight: 400; color: var(--color-text-on-color-body); line-height: 1.5; }
  .tt-link { display: inline-flex; align-items: center; gap: 4px; font-size: 12px; font-weight: 600; color: var(--color-secondary); text-decoration: none; padding: 0 16px 12px; transition: color .15s; }
  .tt-link:hover, .tt-link:focus-visible { color: var(--color-primary); }
  .tt-arrow { position: absolute; width: 0; height: 0; z-index: 1; }
  .tt-arrow.arrow-bottom { left: 50%; transform: translateX(-50%); bottom: -6px; border-left: 6px solid transparent; border-right: 6px solid transparent; border-top: 6px solid var(--neutral-950); }
  .tt-arrow.arrow-top    { left: 50%; transform: translateX(-50%); top: -6px; border-left: 6px solid transparent; border-right: 6px solid transparent; border-bottom: 6px solid var(--neutral-950); }
  .tt-arrow.arrow-left   { top: 50%; transform: translateY(-50%); left: -6px; border-top: 6px solid transparent; border-bottom: 6px solid transparent; border-right: 6px solid var(--neutral-950); }
  .tt-arrow.arrow-right  { top: 50%; transform: translateY(-50%); right: -6px; border-top: 6px solid transparent; border-bottom: 6px solid transparent; border-left: 6px solid var(--neutral-950); }
</style>

<script>
  /* Pure-CSS :hover breaks when there's a gap between trigger and bubble (mouse
     crosses empty space before reaching a link inside). JS with a short close-delay
     keeps it open while moving from the trigger, across the gap, into the bubble. */
  function initTooltips(root: ParentNode = document) {
    root.querySelectorAll<HTMLElement>('.tt.show-on-hover:not([data-tt-init])').forEach((tt) => {
      tt.dataset.ttInit = '1';
      const bubble = tt.querySelector<HTMLElement>('.tt-bubble');
      if (!bubble) return;
      let closeTimer: ReturnType<typeof setTimeout> | null = null;
      const open = () => { if (closeTimer) clearTimeout(closeTimer); bubble.classList.add('js-open'); };
      const scheduleClose = () => {
        if (closeTimer) clearTimeout(closeTimer);
        closeTimer = setTimeout(() => bubble.classList.remove('js-open'), 200);
      };
      tt.addEventListener('mouseenter', open);
      tt.addEventListener('mouseleave', scheduleClose);
      tt.addEventListener('focusin', open);
      tt.addEventListener('focusout', scheduleClose);
      // WCAG 1.4.13 — dismissible: Esc hides the bubble without moving focus.
      tt.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && bubble.classList.contains('js-open')) {
          if (closeTimer) clearTimeout(closeTimer);
          bubble.classList.remove('js-open');
        }
      });
    });
  }

  document.addEventListener('DOMContentLoaded', () => initTooltips());
  document.addEventListener('astro:page-load', () => initTooltips());
</script>
