---
interface Props {
  label?: string;
  description?: string;
  id?: string;
  name: string;
  value: string;
  checked?: boolean;
  invalid?: boolean;
  disabled?: boolean;
  card?: boolean;
  class?: string;
}

const {
  label,
  description,
  id,
  name,
  value,
  checked = false,
  invalid = false,
  disabled = false,
  card = false,
  class: className,
} = Astro.props;

const inputId = id ?? `${name}-${value}`;
---

<label class:list={['rdo', { invalid, disabled, 'rdo-card': card }, className]} for={inputId}>
  <input id={inputId} name={name} value={value} type="radio" checked={checked} disabled={disabled} />
  <span class="dot"></span>
  {label && (
    <span class="txt">
      <span class="label">{label}</span>
      {description && <span class="desc">{description}</span>}
    </span>
  )}
</label>

<style>
  .rdo { display: inline-flex; align-items: flex-start; gap: var(--spacing-xs); cursor: pointer; user-select: none; }
  .rdo input { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
  .rdo .dot {
    width: var(--size-box); height: var(--size-box); flex-shrink: 0; margin-top: 1px;
    border: 1.5px solid var(--color-border-strong); border-radius: var(--rounded-full);
    background: #fff; display: inline-flex; align-items: center; justify-content: center;
    transition: border-color .15s, box-shadow .15s;
  }
  .rdo .dot::after { content: ''; width: 8px; height: 8px; border-radius: var(--rounded-full); background: var(--color-secondary); transform: scale(0); transition: transform .15s; }
  .rdo input:checked + .dot { border-color: var(--color-secondary); }
  .rdo input:checked + .dot::after { transform: scale(1); }
  .rdo input:focus-visible + .dot { box-shadow: var(--shadow-focus-blue); }
  .rdo .txt { display: flex; flex-direction: column; }
  .rdo .txt .label { font-size: var(--font-size-label); font-weight: var(--fw-label); color: var(--color-text-heading); line-height: 1.3; }
  .rdo .txt .desc { font-size: var(--font-size-caption); color: var(--color-text-support); margin-top: 3px; line-height: 1.5; max-width: 360px; }
  .rdo.invalid .dot { border-color: var(--color-danger); }
  .rdo.invalid input:checked + .dot::after { background: var(--color-danger); }
  .rdo.disabled { cursor: not-allowed; opacity: .5; }
  .rdo-card { border: 1.5px solid var(--color-border); border-radius: var(--rounded-xl); padding: 14px 16px; transition: border-color .15s, background .15s; cursor: pointer; max-width: 400px; }
  .rdo-card:hover { border-color: var(--color-border-strong); }
  .rdo-card:has(input:checked) { border-color: var(--color-secondary); background: var(--color-bg-card-alt); }
</style>
