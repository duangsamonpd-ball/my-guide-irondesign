---
interface Props {
  label?: string;
  description?: string;
  id?: string;
  name?: string;
  checked?: boolean;
  invalid?: boolean;
  disabled?: boolean;
  card?: boolean;
  class?: string;
}

const {
  label,
  description,
  id,
  name,
  checked = false,
  invalid = false,
  disabled = false,
  card = false,
  class: className,
} = Astro.props;

const inputId = id ?? name ?? `cbx-${Math.random().toString(36).slice(2, 9)}`;
---

<label class:list={['cbx', { invalid, disabled, 'cbx-card': card }, className]} for={inputId}>
  <input id={inputId} name={name} type="checkbox" checked={checked} disabled={disabled} />
  <span class="box">
    <svg viewBox="0 0 12 12" fill="none">
      <path d="M2 6.2 4.6 8.8 10 3" stroke="#fff" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
    </svg>
  </span>
  {label && (
    <span class="txt">
      <span class="label">{label}</span>
      {description && <span class="desc">{description}</span>}
    </span>
  )}
</label>

<style>
  .cbx { display: inline-flex; align-items: flex-start; gap: var(--spacing-xs); cursor: pointer; user-select: none; }
  .cbx input { position: absolute; width: 1px; height: 1px; opacity: 0; pointer-events: none; }
  .cbx .box {
    width: var(--size-box); height: var(--size-box); flex-shrink: 0; margin-top: 1px;
    border: 1.5px solid var(--color-border-strong); border-radius: var(--rounded-sm);
    background: #fff; display: inline-flex; align-items: center; justify-content: center;
    transition: background .15s, border-color .15s, box-shadow .15s;
  }
  .cbx .box svg { width: 11px; height: 11px; opacity: 0; transform: scale(.5); transition: opacity .15s, transform .15s; }
  .cbx input:checked + .box { background: var(--color-secondary); border-color: var(--color-secondary); }
  .cbx input:checked + .box svg { opacity: 1; transform: scale(1); }
  .cbx input:focus-visible + .box { box-shadow: var(--shadow-focus-blue); }
  .cbx .txt { display: flex; flex-direction: column; }
  .cbx .txt .label { font-size: var(--font-size-label); font-weight: var(--fw-label); color: var(--color-text-heading); line-height: 1.3; }
  .cbx .txt .desc  { font-size: var(--font-size-caption); color: var(--color-text-support); margin-top: 3px; line-height: 1.5; max-width: 360px; }
  .cbx.invalid .box { border-color: var(--color-danger); }
  .cbx.invalid input:checked + .box { background: var(--color-danger); border-color: var(--color-danger); }
  .cbx.disabled { cursor: not-allowed; opacity: .5; }
  .cbx-card { border: 1.5px solid var(--color-border); border-radius: var(--rounded-xl); padding: 14px 16px; transition: border-color .15s, background .15s; cursor: pointer; max-width: 400px; }
  .cbx-card:hover { border-color: var(--color-border-strong); }
  .cbx-card:has(input:checked) { border-color: var(--color-secondary); background: var(--color-bg-card-alt); }
</style>
